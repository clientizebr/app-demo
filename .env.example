# URL base da Clientize (sem barra no final)
CLIENTIZE_URL=https://app.clientize.test

# Client ID do seu app (visível na página do app no portal de parceiros)
CLIENTIZE_CLIENT_ID=

# Client Secret do seu app (exibido apenas na criação)
CLIENTIZE_CLIENT_SECRET=

# Signing Secret do seu app (exibido apenas na criação)
CLIENTIZE_SIGNING_SECRET=
